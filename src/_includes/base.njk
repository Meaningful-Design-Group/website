<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <meta property="og:title" content="{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}">
  <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
  <meta property="og:type" content="website">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/mdg.css">
  {% if threeJs %}<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>{% endif %}
</head>
<body class="batik-bg">

  <!-- Navigation -->
  <nav class="nav">
    <a href="/" class="nav-logo">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
        <path d="M16 8v16M8 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      MDG
    </a>
    <ul class="nav-links">
      <li><a href="/about/" {% if navActive == 'about' %}class="active"{% endif %}>About</a></li>
      <li><a href="/work/" {% if navActive == 'work' or navActive == 'project' %}class="active"{% endif %}>Work</a></li>
      <li><a href="/programs/" {% if navActive == 'programs' %}class="active"{% endif %}>Programs</a></li>
      <li><a href="/research/" {% if navActive == 'research' %}class="active"{% endif %}>Research</a></li>
      <li><a href="/news/" {% if navActive == 'news' %}class="active"{% endif %}>News</a></li>
    </ul>
    <a href="/contact/" class="nav-cta {% if navActive == 'contact' %}active{% endif %}">Get Involved</a>
    <div class="nav-hamburger">
      <span></span><span></span><span></span>
    </div>
  </nav>

  <!-- Main content injected by child templates -->
  <main>
    {{ content | safe }}
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-container">
      <div class="footer-grid">
        <div class="footer-col footer-brand">
          <div class="footer-logo">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5"/>
              <path d="M16 8v16M8 16h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>MDG</span>
          </div>
          <p class="footer-tagline">{{ site.tagline }}</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Work</h4>
          <ul class="footer-links">
            <li><a href="/fab-lab/">Fab Lab Bali</a></li>
            <li><a href="/hydrogen-village/">Hydrogen Village</a></li>
            <li><a href="/bali-fab-fest/">Bali Fab Fest</a></li>
            <li><a href="/fab-island/">Fab Island</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Programs</h4>
          <ul class="footer-links">
            <li><a href="/programs/">Master DDDI</a></li>
            <li><a href="/programs/">Fab Academy</a></li>
            <li><a href="/programs/">Learning Journeys</a></li>
            <li><a href="/programs/">Vocational</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">Connect</h4>
          <ul class="footer-links">
            <li><a href="/about/">About</a></li>
            <li><a href="/research/">Research</a></li>
            <li><a href="/contact/">Contact</a></li>
            {% if site.instagram %}<li><a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a></li>{% endif %}
            {% if site.linkedin %}<li><a href="{{ site.linkedin }}" target="_blank" rel="noopener">LinkedIn</a></li>{% endif %}
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>{{ site.copyright }}</p>
      </div>
    </div>
  </footer>

  <script src="/assets/js/mdg-bg.js"></script>
</body>
</html>
