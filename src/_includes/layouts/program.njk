---
layout: base.njk
---
  <!-- Program Hero -->
  <section class="page-hero" data-accent="{{ accent or 'terra' }}">
    <div class="page-hero-content">
      <p class="sec-label">Education Program</p>
      <h1 class="page-hero-title">{{ heroTitle or title }}</h1>
      <p class="page-hero-lead">{{ heroText or description }}</p>
      {% if applyUrl %}
      <div class="btn-row" style="margin-top:32px;">
        <a href="{{ applyUrl }}" class="btn btn--primary" target="_blank" rel="noopener">Apply Now</a>
        <a href="/programs/" class="btn btn--ghost">All Programs</a>
      </div>
      {% endif %}
    </div>
    <svg class="page-hero-polygon" width="320" height="320" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g stroke="var(--terra)" stroke-width="0.5" opacity="0.28">
        <rect x="40" y="40" width="240" height="240" rx="4" fill="none"/>
        <rect x="80" y="80" width="160" height="160" rx="4" fill="none" transform="rotate(15,160,160)"/>
        <rect x="100" y="100" width="120" height="120" rx="4" fill="none" transform="rotate(30,160,160)"/>
        <line x1="160" y1="40" x2="160" y2="280"/><line x1="40" y1="160" x2="280" y2="160"/>
        <line x1="80" y1="80" x2="240" y2="240"/><line x1="240" y1="80" x2="80" y2="240"/>
      </g>
    </svg>
  </section>

  <!-- Program Meta -->
  {% if programMeta %}
  <section class="section" style="padding:40px 8vw;border-bottom:1px solid var(--border);">
    <div class="program-meta-strip" style="display:flex;gap:40px;flex-wrap:wrap;">
      {% if programMeta.duration %}
      <div class="program-meta-item">
        <span class="program-meta-label">Duration</span>
        <span class="program-meta-value">{{ programMeta.duration }}</span>
      </div>
      {% endif %}
      {% if programMeta.format %}
      <div class="program-meta-item">
        <span class="program-meta-label">Format</span>
        <span class="program-meta-value">{{ programMeta.format }}</span>
      </div>
      {% endif %}
      {% if programMeta.location %}
      <div class="program-meta-item">
        <span class="program-meta-label">Location</span>
        <span class="program-meta-value">{{ programMeta.location }}</span>
      </div>
      {% endif %}
      {% if programMeta.language %}
      <div class="program-meta-item">
        <span class="program-meta-label">Language</span>
        <span class="program-meta-value">{{ programMeta.language }}</span>
      </div>
      {% endif %}
    </div>
  </section>
  {% endif %}

  <!-- Program Body -->
  <section class="section section-container">
    <div class="rich-text">
      {{ content | safe }}
    </div>
  </section>

  <!-- CTA Band -->
  <section class="cta-band">
    <h2>{{ ctaTitle or "Start your journey" }}</h2>
    <p>{{ ctaText or "Apply now or reach out to learn more about this program." }}</p>
    <div class="btn-row" style="justify-content:center;">
      {% if applyUrl %}
      <a href="{{ applyUrl }}" class="btn btn--primary" target="_blank" rel="noopener">Apply Now</a>
      {% else %}
      <a href="/contact/" class="btn btn--primary">Get in Touch</a>
      {% endif %}
      <a href="/programs/" class="btn btn--ghost">All Programs</a>
    </div>
  </section>
